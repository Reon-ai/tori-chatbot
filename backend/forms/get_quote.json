{
  "id": "get_quote",
  "title": "Get a Quote from Tiletoria",
  "description": "Leave your details below and a Tiletoria consultant will prepare an accurate quote for you.",
  "submitLabel": "Send Quote Request",
  "successMessage": "Thank you! We've received your quote request and one of our team members will contact you shortly.",
  "fields": [
    {
      "name": "name",
      "label": "Your name",
      "type": "text",
      "placeholder": "e.g. Sarah Botha",
      "required": true
    },
    {
      "name": "phone",
      "label": "Phone number",
      "type": "tel",
      "placeholder": "e.g. 082 123 4567",
      "required": true
    },
    {
      "name": "email",
      "label": "Email address",
      "type": "email",
      "placeholder": "e.g. sarah@email.com",
      "required": false
    },
    {
      "name": "store",
      "label": "Preferred Tiletoria store",
      "type": "select",
      "required": false,
      "options": [
        "No preference",
        "Cape Town — Paarden Eiland",
        "Paarl — Specification Lab",
        "Somerset West",
        "Bellville",
        "George"
      ]
    },
    {
      "name": "productType",
      "label": "What are you looking for?",
      "type": "select",
      "required": false,
      "options": [
        "Floor tiles",
        "Wall tiles",
        "Outdoor / paving tiles",
        "Vinyl flooring",
        "Laminate flooring",
        "Sanware (toilets, basins, baths)",
        "Adhesive / Grout",
        "Multiple products",
        "Not sure yet"
      ]
    },
    {
      "name": "sqm",
      "label": "Approximate area (m²)",
      "type": "number",
      "placeholder": "e.g. 45",
      "required": false
    },
    {
      "name": "details",
      "label": "Tell us what you need",
      "type": "textarea",
      "placeholder": "Describe the products, style, colours, room type, or any specific requirements…",
      "required": true
    },
    {
      "name": "consent",
      "label": "I consent to Tiletoria storing and using my details to contact me about my enquiry, in accordance with the POPI Act.",
      "type": "checkbox",
      "required": true
    }
  ]
}