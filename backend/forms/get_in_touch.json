{
  "id": "get_in_touch",
  "title": "Speak to a Tiletoria Consultant",
  "description": "Leave your details and one of our team members will call or WhatsApp you back.",
  "submitLabel": "Request Callback",
  "successMessage": "Thank you! We've received your details and a consultant will be in touch with you shortly.",
  "fields": [
    {
      "name": "name",
      "label": "Your name",
      "type": "text",
      "placeholder": "e.g. John Smith",
      "required": true
    },
    {
      "name": "phone",
      "label": "Phone number",
      "type": "tel",
      "placeholder": "e.g. 071 123 4567",
      "required": true
    },
    {
      "name": "email",
      "label": "Email address",
      "type": "email",
      "placeholder": "e.g. john@email.com",
      "required": false
    },
    {
      "name": "store",
      "label": "Nearest Tiletoria store",
      "type": "select",
      "required": false,
      "options": [
        "No preference",
        "Cape Town — Paarden Eiland",
        "Paarl — Specification Lab",
        "Somerset West",
        "Bellville",
        "George"
      ]
    },
    {
      "name": "bestTime",
      "label": "Best time to call",
      "type": "select",
      "required": false,
      "options": [
        "Any time",
        "Morning (8am – 12pm)",
        "Afternoon (12pm – 5pm)",
        "After hours"
      ]
    },
    {
      "name": "details",
      "label": "How can we help you?",
      "type": "textarea",
      "placeholder": "Briefly tell us what you need help with…",
      "required": false
    },
    {
      "name": "consent",
      "label": "I consent to Tiletoria storing and using my details to contact me about my enquiry, in accordance with the POPI Act.",
      "type": "checkbox",
      "required": true
    }
  ]
}