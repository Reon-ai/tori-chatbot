# ================================================================
# .env.example
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ================================================================

# ── OpenAI (REQUIRED) ──────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── Application ────────────────────────────────────────────────
APP_NAME=RAG Chatbot API
ENVIRONMENT=production        # development | production
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
VERSION=1.0.0

# ── CORS (comma-separated origins) ─────────────────────────────
# Development:
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5500
# Production (replace with your actual domain):
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Vector Database ────────────────────────────────────────────
VECTOR_DB_TYPE=chromadb          # chromadb | pinecone | qdrant
VECTOR_DB_PATH=./data/vectordb
VECTOR_DB_COLLECTION=rag_documents

# Pinecone (only if VECTOR_DB_TYPE=pinecone)
# PINECONE_API_KEY=your-pinecone-api-key
# PINECONE_ENVIRONMENT=us-east-1
# PINECONE_INDEX_NAME=rag-chatbot

# Qdrant (only if VECTOR_DB_TYPE=qdrant)
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# ── OpenAI Models ──────────────────────────────────────────────
OPENAI_EMBEDDING_MODEL=text-embedding-3-small  # most cost-effective
OPENAI_CHAT_MODEL=gpt-4o-mini                  # gpt-4o-mini | gpt-4-turbo | gpt-4o
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=500

# ── SQLite ─────────────────────────────────────────────────────
SQLITE_PATH=./data/chatbot.db

# ── Documents ──────────────────────────────────────────────────
DOCUMENTS_DIR=./documents
MAX_FILE_SIZE_MB=50

# ── RAG Parameters ─────────────────────────────────────────────
CHUNK_SIZE=800                # tokens per chunk
CHUNK_OVERLAP=150             # token overlap between chunks
TOP_K=5                       # number of chunks to retrieve per query
SIMILARITY_THRESHOLD=0.7      # minimum similarity score (0.0–1.0)
MEMORY_TURNS=5                # conversation turns to include as context

# ── Admin Panel ────────────────────────────────────────────────
ADMIN_PASSWORD=change-me-to-a-secure-password   # CHANGE THIS!
ADMIN_SESSION_SECRET=change-me-to-random-32-char-string

# ── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30

# ── Analytics ──────────────────────────────────────────────────
ENABLE_ANALYTICS=true
CONVERSATION_RETENTION_DAYS=90

# ── Business Customisation ─────────────────────────────────────
BUSINESS_NAME=ShopBot AI

# ── Email / Form Notifications ─────────────────────────────────
# Where form submission emails are sent (e.g. sales@yourcompany.com)
NOTIFICATION_EMAIL=your-sales-email@example.com

# SMTP settings for sending email notifications
# If not configured, form submissions are still saved to the database
SMTP_HOST=smtp.gmail.com              # or your SMTP server
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@example.com      # sender address

# ── Form Intent Detection ──────────────────────────────────────
INTENT_CONFIDENCE_THRESHOLD=0.45      # 0.0–1.0, lower = more sensitive
FORM_SHORT_CIRCUIT=true               # if true, skip RAG when form intent detected

# ── Session Memory ─────────────────────────────────────────────
# How many new messages before regenerating the AI summary
MEMORY_SUMMARY_INTERVAL=3             # higher = fewer LLM calls, lower cost
# How many recent messages to send to the AI prompt
MEMORY_TURNS=10                       # 8–12 recommended
# Days to keep session memory before auto-cleanup
MEMORY_RETENTION_DAYS=30              # 7–30 days recommended

# ── Vision / Image Analysis ────────────────────────────────────
# OpenAI vision model for analysing uploaded images
VISION_MODEL=gpt-4o-mini              # must support vision (gpt-4o-mini or gpt-4o)
# Maximum images per chat message
VISION_MAX_IMAGES=3
# Maximum image file size in MB
VISION_MAX_IMAGE_SIZE_MB=5