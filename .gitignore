# ================================================================
# .gitignore
# ================================================================

# ── Environment & Secrets ──────────────────────────────────────
.env
.env.local
.env.production
*.key
*.pem

# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl
.pytest_cache/
.coverage
htmlcov/
.tox/
.venv/
venv/
env/
.mypy_cache/
.ruff_cache/

# ── Data (generated at runtime) ────────────────────────────────
data/
!data/.gitkeep

# ── Node.js ────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.next/
out/

# ── IDEs ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Docker ─────────────────────────────────────────────────────
docker-compose.override.yml

# ── Nginx ──────────────────────────────────────────────────────
nginx/certs/
